# ─────────────────────────────────────────────────────────────────────────────
# RepoLens — Environment Variables
# Copy this file to .env at the repo root and fill in the values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Amazon Nova API key (required)
# Obtain from https://nova.amazon.com
NOVA_API_KEY=your_nova_api_key_here

# Backend URL as seen by the browser (required for frontend)
# In dev this is always http://localhost:8000
# In production set to your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: override the CORS origin allowed by the backend
# Defaults to http://localhost:3000
# CORS_ORIGIN=http://localhost:3000
